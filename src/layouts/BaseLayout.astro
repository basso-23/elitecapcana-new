---
import "../styles/index.css";
import "@fontsource/cormorant-garamond/400.css";
import "@fontsource/cormorant-garamond/500.css";
import "@fontsource/manrope/400.css";
import "@fontsource/manrope/500.css";
import "@fontsource/manrope/600.css";
import "intl-tel-input/styles";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";

interface Props {
	title?: string;
	description?: string;
	robots?: string;
}

const {
	title = "Elite Cap Cana | Residencias frente al Caribe",
	description = "Elite Cap Cana, residencias exclusivas frente al Caribe en una de las comunidades más prestigiosas de República Dominicana.",
	robots,
} = Astro.props;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" sizes="256x256" href="/favicon.ico" />
		<link rel="shortcut icon" type="image/png" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		{robots && <meta name="robots" content={robots} />}
		<title>{title}</title>
	</head>
	<body>
		<main class="site_shell">
			<SiteHeader />
			<slot />
			<SiteFooter />
		</main>
	</body>
</html>
