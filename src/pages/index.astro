		<script>
			const setupResidenceCarousels = () => {
				document.querySelectorAll("[data-residence-carousel]").forEach((carousel) => {
					const track = carousel.querySelector("[data-residence-track]");
					const prev = carousel.querySelector("[data-residence-prev]");
					const next = carousel.querySelector("[data-residence-next]");
					if (!track || !prev || !next) return;

					const cards = Array.from(track.children);
					let activeIndex = 0;

					const getColumnCount = () => {
						const columns = window.getComputedStyle(track).gridTemplateColumns;
						return columns.split(" ").filter(Boolean).length || 1;
					};

					const update = () => {
						const firstCard = cards[0];
						if (!firstCard) return;

						const styles = window.getComputedStyle(track);
						const rowGap = parseFloat(styles.rowGap) || 0;
						const columns = getColumnCount();
						const maxIndex = Math.max(0, Math.ceil(cards.length / columns) - 1);
						activeIndex = Math.min(activeIndex, maxIndex);

						const step = firstCard.getBoundingClientRect().height + rowGap;
						track.style.transform = `translateY(${-activeIndex * step}px)`;
						prev.disabled = activeIndex === 0;
						next.disabled = activeIndex === maxIndex;
					};

					prev.addEventListener("click", () => {
						activeIndex = Math.max(0, activeIndex - 1);
						update();
					});

					next.addEventListener("click", () => {
						activeIndex += 1;
						update();
					});

					window.addEventListener("resize", update);
					update();
				});
			};

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", setupResidenceCarousels);
			} else {
				setupResidenceCarousels();
			}
		</script>
