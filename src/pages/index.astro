<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
		<script src="https://cdn.jsdelivr.net/gh/sanserna/owly-webflow@2.0.0/dist/owly-webflow.umd.min.js"></script>
		<script>
			import intlTelInput from "intl-tel-input/intlTelInputWithUtils";

			const setupResidenceCarousels = () => {
				document.querySelectorAll("[data-residence-carousel]").forEach((carousel) => {
					const track = carousel.querySelector("[data-residence-track]");
					const prev = carousel.querySelector("[data-residence-prev]");
					const next = carousel.querySelector("[data-residence-next]");
					if (!track || !prev || !next) return;

					const cards = Array.from(track.children);
					let activeIndex = 0;

					const getColumnCount = () => {
						const columns = window.getComputedStyle(track).gridTemplateColumns;
						return columns.split(" ").filter(Boolean).length || 1;
					};

					const update = () => {
						const firstCard = cards[0];
						if (!firstCard) return;

						const styles = window.getComputedStyle(track);
						const rowGap = parseFloat(styles.rowGap) || 0;
						const columns = getColumnCount();
						const maxIndex = Math.max(0, Math.ceil(cards.length / columns) - 1);
						activeIndex = Math.min(activeIndex, maxIndex);

						const step = firstCard.getBoundingClientRect().height + rowGap;
						track.style.transform = `translateY(${-activeIndex * step}px)`;
						prev.disabled = activeIndex === 0;
						next.disabled = activeIndex === maxIndex;
					};

					prev.addEventListener("click", () => {
						activeIndex = Math.max(0, activeIndex - 1);
						update();
					});

					next.addEventListener("click", () => {
						activeIndex += 1;
						update();
					});

					window.addEventListener("resize", update);
					update();
				});
			};

			const setupResidenceModal = () => {
				const modal = document.querySelector("[data-residence-modal]");
				const modalImage = document.querySelector("[data-residence-modal-image]");
				const closeButton = document.querySelector("[data-residence-modal-close]");
				const triggers = document.querySelectorAll("[data-residence-modal-src]");
				if (!modal || !modalImage || !closeButton || !triggers.length) return;

				let activeTrigger = null;

				const closeModal = () => {
					modal.classList.remove("residence_modal_open");
					modal.setAttribute("aria-hidden", "true");
					document.body.classList.remove("body_modal_locked");
					modalImage.setAttribute("src", "");
					modalImage.setAttribute("alt", "");

					if (activeTrigger) {
						activeTrigger.focus();
						activeTrigger = null;
					}
				};

				const openModal = (trigger) => {
					const src = trigger.getAttribute("data-residence-modal-src");
					if (!src) return;

					const card = trigger.closest(".residence_card");
					const title = card?.querySelector("h3")?.textContent?.trim() || "Apartamento";
					const details = Array.from(card?.querySelectorAll(".residence_card_fact span") || [])
						.map((item) => item.textContent.trim())
						.filter(Boolean)
						.join(", ");

					activeTrigger = trigger;
					modalImage.setAttribute("src", src);
					modalImage.setAttribute("alt", `Plano detallado ${title}${details ? `, ${details}` : ""}`);
					modal.classList.add("residence_modal_open");
					modal.setAttribute("aria-hidden", "false");
					document.body.classList.add("body_modal_locked");
					closeButton.focus();
				};

				triggers.forEach((trigger) => {
					trigger.addEventListener("click", (event) => {
						event.preventDefault();
						openModal(trigger);
					});
				});

				closeButton.addEventListener("click", closeModal);
				modal.addEventListener("click", (event) => {
					if (event.target === modal) closeModal();
				});

				document.addEventListener("keydown", (event) => {
					if (event.key === "Escape" && modal.classList.contains("residence_modal_open")) {
						closeModal();
					}
				});
			};

			const setupContactForm = () => {
				const form = document.querySelector("[data-contact-form]");
				const phoneInput = document.querySelector("[data-phone-input]");
				if (!form || !phoneInput) return;

				const phone = intlTelInput(phoneInput, {
					initialCountry: "do",
					separateDialCode: true,
					nationalMode: true,
				});

				const updatePhoneValue = () => {
					const internationalPhone = phone.getNumber();
					if (internationalPhone) phoneInput.value = internationalPhone;
				};

				form.addEventListener("submit", (event) => {
					updatePhoneValue();

					if (!form.checkValidity()) {
						event.preventDefault();
						form.reportValidity();
					}
				});
			};

			const setupCountryCityFields = () => {
				const countrySelect = document.querySelector("[data-country-select]");
				const citySelect = document.querySelector("[data-city-select]");
				if (!countrySelect || !citySelect) return;

				let countriesData = [];

				const setCityOptions = (cities = []) => {
					citySelect.innerHTML = "";
					citySelect.add(new Option("Ciudad", ""));
					cities.forEach((city) => citySelect.add(new Option(city, city)));
				};

				fetch("https://countriesnow.space/api/v0.1/countries")
					.then((response) => response.json())
					.then((data) => {
						countriesData = Array.isArray(data.data) ? data.data : [];
					})
					.catch((error) => {
						console.error("Error cargando ciudades:", error);
					});

				countrySelect.addEventListener("change", () => {
					const country = countriesData.find((item) => item.country === countrySelect.value);
					setCityOptions(country?.cities || []);
				});
			};

			const setupLeadFormIntegration = () => {
				const form = document.querySelector("#leadForm");
				const submitButton = form?.querySelector("[data-button='submit']");
				if (!form || !submitButton) return;

				const owlyWebflow = (window as typeof window & {
					owlyWebflow?: { initForm?: (selector: string) => void };
				}).owlyWebflow;

				if (owlyWebflow?.initForm) {
					owlyWebflow.initForm("#leadForm");
				}

				form.addEventListener("submit", () => {
					if (!form.checkValidity()) return;

					const redirectUrl = submitButton.getAttribute("data-redirect-url");
					if (redirectUrl) {
						window.setTimeout(() => {
							window.location.href = redirectUrl;
						}, 2000);
					}
				});
			};

			const setupPageInteractions = () => {
				setupResidenceCarousels();
				setupResidenceModal();
				setupContactForm();
				setupCountryCityFields();
				setupLeadFormIntegration();
			};

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", setupPageInteractions);
			} else {
				setupPageInteractions();
			}
		</script>
