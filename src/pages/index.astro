---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
			<section class="hero_section" id="home" aria-label="Elite Cap Cana">
				<img
					class="hero_image"
					src="/assets/hero/hero_residences_caribbean_luxury.webp"
					alt="Residencias de lujo frente al Caribe con piscina infinita y palmeras en Cap Cana"
					loading="eager"
					decoding="async"
					fetchpriority="high"
				/>
				<div class="hero_overlay hero_overlay_left"></div>
				<div class="hero_overlay hero_overlay_top"></div>
				<div class="hero_overlay hero_overlay_bottom"></div>

				<div class="hero_content_wrap">
					<div class="hero_content">
						<h1>Invierte en Cap Cana. Vive frente al Caribe.</h1>
						<p class="hero_kicker">Un destino extraordinario. Una inversión excepcional.</p>

						<div class="hero_actions">
							<a class="primary_cta button_base" href="#contacto">
								<span>Solicita información</span>
								<span class="cta_arrow" aria-hidden="true"></span>
							</a>
							<div class="hero_hint" aria-hidden="true">
								<svg class="hint_arrow_icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 100" aria-hidden="true">
									<path d="M 175,25 C 140,65 75,75 35,45 M 35,45 L 65,37 M 35,45 L 53,70" />
								</svg>
								<span>Te conecta<br />con nuestro formulario<br />de contacto.</span>
							</div>
						</div>
					</div>
				</div>

				<a class="scroll_cue" href="#entrada" aria-label="Ir a la siguiente sección">
					<span class="scroll_mouse"></span>
					<span class="scroll_line"></span>
				</a>
			</section>

			<section class="entrance_section" id="entrada" aria-labelledby="entrada_title">
				<div class="entrance_inner section_inner">
					<div class="entrance_copy section_copy">
						<svg class="entrance_palm_icon line_icon" viewBox="0 0 52 52" aria-hidden="true">
							<path d="M26 47V23" />
							<path d="M26 23C21.7 27.4 19.6 32 19.4 37.5" />
							<path d="M26 23C30.3 27.4 32.4 32 32.6 37.5" />
							<path d="M26 21C18.4 20.9 12.6 23.3 8.6 28.2" />
							<path d="M26 21C33.6 20.9 39.4 23.3 43.4 28.2" />
							<path d="M25.8 20.2C20.1 14.8 14.2 12.9 8.2 14.6" />
							<path d="M26.2 20.2C31.9 14.8 37.8 12.9 43.8 14.6" />
							<path d="M26 19.2C24.1 12.9 24.7 7.9 27.8 4.1" />
							<path d="M26 19.2C28.7 13.7 32.4 10.3 37.2 9" />
							<path d="M26 19.2C23.3 13.7 19.6 10.3 14.8 9" />
						</svg>

						<h2 class="section_title" id="entrada_title">Entrada elegante<br />a una vida de lujo</h2>
						<span class="entrance_rule gold_rule" aria-hidden="true"></span>
						<p class="section_text">
							Elite Cap Cana es un proyecto residencial exclusivo dentro de la comunidad más
							prestigiosa del Caribe. Diseñado para quienes buscan elevar su estilo de vida
							y hacer una inversión con visión de futuro.
						</p>

						<div class="entrance_stats" aria-label="Datos principales del proyecto">
							<div class="entrance_stat">
								<svg class="stat_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
									<path d="M11 37V13l11-5 11 5v24" />
									<path d="M16 37V19h12v18" />
									<path d="M18 24h2M24 24h2M18 29h2M24 29h2" />
									<path d="M8 37h28" />
								</svg>
								<strong>113</strong>
								<span>Residencias<br />exclusivas</span>
							</div>
							<div class="entrance_stat">
								<svg class="stat_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
									<path d="M9 31V17" />
									<path d="M9 23h26c3 0 5 2 5 5v3" />
									<path d="M9 31h31" />
									<path d="M14 23v-6h9c3 0 5 2 5 5v1" />
									<path d="M13 35v-4M38 35v-4" />
								</svg>
								<strong>1, 2 y 4</strong>
								<span>Habitaciones</span>
							</div>
							<div class="entrance_stat">
								<svg class="stat_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
									<path d="M6 23c4-5 8-5 12 0s8 5 12 0 6-5 8-3" />
									<path d="M6 31c4-5 8-5 12 0s8 5 12 0 6-5 8-3" />
								</svg>
								<span>Vistas al mar</span>
								<span>y Farallón</span>
							</div>
						</div>
					</div>

					<div class="entrance_visual" aria-hidden="true">
						<img
							src="/assets/section_entrada/entrada_residences_aerial.webp"
							alt=""
							loading="lazy"
							decoding="async"
						/>
					</div>
				</div>
			</section>

			<section class="location_section" id="ubicacion" aria-labelledby="ubicacion_title">
				<div class="location_inner section_inner">
					<div class="entrance_copy location_copy section_copy">
						<svg class="entrance_palm_icon line_icon" viewBox="0 0 52 52" aria-hidden="true">
							<path d="M26 47V23" />
							<path d="M26 23C21.7 27.4 19.6 32 19.4 37.5" />
							<path d="M26 23C30.3 27.4 32.4 32 32.6 37.5" />
							<path d="M26 21C18.4 20.9 12.6 23.3 8.6 28.2" />
							<path d="M26 21C33.6 20.9 39.4 23.3 43.4 28.2" />
							<path d="M25.8 20.2C20.1 14.8 14.2 12.9 8.2 14.6" />
							<path d="M26.2 20.2C31.9 14.8 37.8 12.9 43.8 14.6" />
							<path d="M26 19.2C24.1 12.9 24.7 7.9 27.8 4.1" />
							<path d="M26 19.2C28.7 13.7 32.4 10.3 37.2 9" />
							<path d="M26 19.2C23.3 13.7 19.6 10.3 14.8 9" />
						</svg>

						<h2 class="section_title" id="ubicacion_title">Ubicación<br />privilegiada</h2>
						<span class="entrance_rule gold_rule" aria-hidden="true"></span>
						<p class="section_text">
							En el corazón de Cap Cana, rodeado de experiencias únicas y servicios
							de clase mundial.
						</p>
						<div class="location_actions" aria-label="Abrir ubicación en mapas">
							<a class="location_map_button button_base" href="https://maps.app.goo.gl/KHo49GD7U2qZGhoG7" target="_blank" rel="noopener noreferrer">
								<svg viewBox="0 0 24 24" aria-hidden="true">
									<path d="M12 21s7-5.4 7-11a7 7 0 0 0-14 0c0 5.6 7 11 7 11Z" />
									<circle cx="12" cy="10" r="2.6" />
								</svg>
								<span>Google Maps</span>
							</a>
							<a class="location_map_button button_base" href="https://www.waze.com/es-419/live-map/directions?navigate=yes&amp;utm_campaign=default&amp;utm_source=waze_website&amp;utm_medium=lm_share_location&amp;to=ll.18.46839516%2C-68.41725111" target="_blank" rel="noopener noreferrer">
								<img src="/assets/icons/waze.svg" alt="" aria-hidden="true" loading="lazy" decoding="async" />
								<span>Waze</span>
							</a>
						</div>
					</div>

					<div class="location_map">
						<img
							src="/assets/section_ubicacion/cap_cana_map_complete.webp"
							alt="Mapa ilustrado de Cap Cana con ubicación del proyecto y puntos de referencia cercanos"
							loading="lazy"
							decoding="async"
						/>
					</div>

					<div class="location_places" aria-label="Puntos de interés cercanos">
						<div class="location_place feature_row">
							<svg class="location_place_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
								<path d="M22 25V9" />
								<path d="M22 11C17 12 13.5 14.6 11.5 18.8" />
								<path d="M22 11C27 12 30.5 14.6 32.5 18.8" />
								<path d="M21.8 10.8C18.4 6.8 14.8 5.6 11 7.1" />
								<path d="M22.2 10.8C25.6 6.8 29.2 5.6 33 7.1" />
								<path d="M8 32c3.8-3.6 7.5-3.6 11.3 0s7.5 3.6 11.2 0 5.3-3.6 6.5-2.2" />
								<path d="M8 38c3.8-3.6 7.5-3.6 11.3 0s7.5 3.6 11.2 0 5.3-3.6 6.5-2.2" />
							</svg>
							<p><span>Playa Juanillo</span><strong>5 min.</strong></p>
						</div>
						<div class="location_place feature_row">
							<svg class="location_place_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
								<path d="M13 38V9" />
								<path d="M13 10h18l-4 6 4 6H13" />
								<path d="M9 38h12" />
								<path d="M28 34c4 0 7-1.8 7-4s-3-4-7-4-7 1.8-7 4 3 4 7 4Z" />
							</svg>
							<p><span>Punta Espada Golf Club</span><strong>5 min.</strong></p>
						</div>
						<div class="location_place feature_row">
							<svg class="location_place_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
								<path d="M22 7v25" />
								<path d="M22 9c-5.8 6.5-8.8 13.7-9 21h9" />
								<path d="M23 12c5.4 4.8 8.5 10.8 9.2 18H23" />
								<path d="M10 37c4-2.8 8-2.8 12 0s8 2.8 12 0" />
							</svg>
							<p><span>Marina Cap Cana</span><strong>7 min.</strong></p>
						</div>
						<div class="location_place feature_row">
							<svg class="location_place_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
								<path d="M31.5 7.5C20 8.5 12.3 16.3 10 31c11.7-.7 19.3-8.4 21.5-23.5Z" />
								<path d="M11 31c5.5-7.2 11.7-12.3 18.6-15.4" />
								<path d="M17 24c1.3 4.7 3.8 8 7.5 10" />
							</svg>
							<p><span>Scape Park</span><strong>10 min.</strong></p>
						</div>
						<div class="location_place feature_row">
							<svg class="location_place_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
								<path d="M6 26l32-14-11 25-6-11-11 5-4-5Z" />
								<path d="M21 26l17-14" />
							</svg>
							<p><span>Aeropuerto Int. Punta Cana</span><strong>12 min.</strong></p>
						</div>
					</div>
				</div>
			</section>

			<section class="hero_section resort_hero" id="vida-resort" aria-labelledby="vida_resort_title">
				<img
					class="hero_image resort_hero_image"
					src="/assets/hero/hero_resort_golf_cap_cana.webp"
					alt="Residencias de lujo con terrazas frente al mar Caribe y campo de golf en Cap Cana"
					loading="lazy"
					decoding="async"
				/>
				<div class="hero_overlay resort_hero_overlay_left"></div>
				<div class="hero_overlay resort_hero_overlay_top"></div>
				<div class="hero_overlay resort_hero_overlay_bottom"></div>

				<div class="hero_content_wrap resort_hero_content_wrap">
					<div class="hero_content resort_hero_content">
						<h1 id="vida_resort_title">Vida resort en una dirección privilegiada</h1>
						<span class="resort_hero_rule" aria-hidden="true"></span>
						<p class="resort_hero_text">
							Un estilo de vida que combina naturaleza, sofisticación y bienestar en el corazón
							de Cap Cana.
						</p>

						<a class="primary_cta resort_hero_cta button_base" href="#contacto">
							<span>Solicita información</span>
							<span class="cta_arrow" aria-hidden="true"></span>
						</a>

						<div class="resort_hero_meta" aria-label="Datos principales de residencias">
							<svg class="location_place_icon resort_hero_meta_icon" viewBox="0 0 44 44" aria-hidden="true">
								<path d="M11 37V13l11-5 11 5v24" />
								<path d="M16 37V19h12v18" />
								<path d="M18 24h2M24 24h2M18 29h2M24 29h2" />
								<path d="M8 37h28" />
							</svg>
							<p>
								<strong>113 RESIDENCIAS EXCLUSIVAS</strong>
								<span>1, 2 y 4 habitaciones</span>
							</p>
						</div>
					</div>
				</div>
			</section>

			<section class="location_section lifestyle_section" id="amenidades" aria-labelledby="lifestyle_title">
				<div class="lifestyle_inner section_inner">
					<div class="entrance_copy location_copy lifestyle_copy section_copy">
						<svg class="entrance_palm_icon line_icon" viewBox="0 0 52 52" aria-hidden="true">
							<path d="M26 47V23" />
							<path d="M26 23C21.7 27.4 19.6 32 19.4 37.5" />
							<path d="M26 23C30.3 27.4 32.4 32 32.6 37.5" />
							<path d="M26 21C18.4 20.9 12.6 23.3 8.6 28.2" />
							<path d="M26 21C33.6 20.9 39.4 23.3 43.4 28.2" />
							<path d="M25.8 20.2C20.1 14.8 14.2 12.9 8.2 14.6" />
							<path d="M26.2 20.2C31.9 14.8 37.8 12.9 43.8 14.6" />
							<path d="M26 19.2C24.1 12.9 24.7 7.9 27.8 4.1" />
							<path d="M26 19.2C28.7 13.7 32.4 10.3 37.2 9" />
							<path d="M26 19.2C23.3 13.7 19.6 10.3 14.8 9" />
						</svg>

						<h2 class="section_title" id="lifestyle_title">Golf, playa y<br />marina a minutos</h2>
						<span class="entrance_rule gold_rule" aria-hidden="true"></span>
						<p class="section_text">
							Vive rodeado de experiencias únicas. Desde campos de golf de clase mundial
							hasta playas de arena blanca y una marina de primer nivel.
						</p>

						<div class="lifestyle_features" aria-label="Amenidades y experiencias cercanas">
							<div class="lifestyle_feature feature_row">
								<svg class="location_place_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
									<path d="M13 38V9" />
									<path d="M13 10h18l-4 6 4 6H13" />
									<path d="M9 38h12" />
									<path d="M28 34c4 0 7-1.8 7-4s-3-4-7-4-7 1.8-7 4 3 4 7 4Z" />
								</svg>
								<span>Punta Espada Golf Course</span>
							</div>
							<div class="lifestyle_feature feature_row">
								<svg class="location_place_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
									<path d="M8 28c4-4.5 8-4.5 12 0s8 4.5 12 0 6-4.5 8-2.2" />
									<path d="M8 35c4-4.5 8-4.5 12 0s8 4.5 12 0 6-4.5 8-2.2" />
									<path d="M13 38V9" />
									<path d="M13 10h18l-4 6 4 6H13" />
								</svg>
								<span>Las Iguanas Golf</span>
							</div>
							<div class="lifestyle_feature feature_row">
								<svg class="location_place_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
									<path d="M9 35h26" />
									<path d="M13 35V17l9-7 9 7v18" />
									<path d="M18 35V23h8v12" />
									<path d="M14 17h16" />
								</svg>
								<span>Los Establos</span>
							</div>
							<div class="lifestyle_feature feature_row">
								<svg class="location_place_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
									<path d="M8 28c4-4.5 8-4.5 12 0s8 4.5 12 0 6-4.5 8-2.2" />
									<path d="M8 35c4-4.5 8-4.5 12 0s8 4.5 12 0 6-4.5 8-2.2" />
									<path d="M22 10c-3.8 3.4-5.8 7.3-6 11.8" />
									<path d="M22 10c3.8 3.4 5.8 7.3 6 11.8" />
								</svg>
								<span>Playa Juanillo</span>
							</div>
							<div class="lifestyle_feature feature_row">
								<svg class="location_place_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
									<path d="M11 36V13l11-6 11 6v23" />
									<path d="M16 36V20h12v16" />
									<path d="M18 25h2M24 25h2M18 30h2M24 30h2" />
									<path d="M8 36h28" />
								</svg>
								<span>Cap Cana Heritage School</span>
							</div>
							<div class="lifestyle_feature feature_row">
								<svg class="location_place_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
									<path d="M22 7v25" />
									<path d="M22 9c-5.8 6.5-8.8 13.7-9 21h9" />
									<path d="M23 12c5.4 4.8 8.5 10.8 9.2 18H23" />
									<path d="M10 37c4-2.8 8-2.8 12 0s8 2.8 12 0" />
								</svg>
								<span>La Marina At Cap Cana</span>
							</div>
						</div>

						<a class="location_text_link lifestyle_text_link button_base" href="#contacto">
							<span>Descubre Cap Cana</span>
							<span class="lifestyle_link_arrow" aria-hidden="true"></span>
						</a>
					</div>

					<div class="lifestyle_gallery" aria-label="Experiencias de Cap Cana">
						<figure class="lifestyle_photo lifestyle_photo_main">
							<img
								src="/assets/section_lifestyle/golf_ocean_main.webp"
								alt="Campo de golf frente al mar Caribe en Cap Cana"
								loading="lazy"
								decoding="async"
							/>
						</figure>
						<figure class="lifestyle_photo">
							<img
								src="/assets/section_lifestyle/marina_cap_cana.webp"
								alt="Marina de lujo con yates, palmeras y faro en Cap Cana"
								loading="lazy"
								decoding="async"
							/>
						</figure>
						<figure class="lifestyle_photo">
							<img
								src="/assets/section_lifestyle/white_sand_beach.webp"
								alt="Playa de arena blanca con agua turquesa y palmeras en Cap Cana"
								loading="lazy"
								decoding="async"
							/>
						</figure>
					</div>

				</div>
			</section>

			<section class="location_section residences_section" id="residencias" aria-labelledby="residencias_title">
				<div class="residences_inner section_inner">
					<div class="residences_header section_header">
						<a class="brand_mark residences_brand" href="/" aria-label="Elite Cap Cana inicio">
							<svg class="brand_palm_icon" viewBox="0 0 52 52" aria-hidden="true">
								<path d="M26 47V23" />
								<path d="M26 23C21.7 27.4 19.6 32 19.4 37.5" />
								<path d="M26 23C30.3 27.4 32.4 32 32.6 37.5" />
								<path d="M26 21C18.4 20.9 12.6 23.3 8.6 28.2" />
								<path d="M26 21C33.6 20.9 39.4 23.3 43.4 28.2" />
								<path d="M25.8 20.2C20.1 14.8 14.2 12.9 8.2 14.6" />
								<path d="M26.2 20.2C31.9 14.8 37.8 12.9 43.8 14.6" />
								<path d="M26 19.2C24.1 12.9 24.7 7.9 27.8 4.1" />
								<path d="M26 19.2C28.7 13.7 32.4 10.3 37.2 9" />
								<path d="M26 19.2C23.3 13.7 19.6 10.3 14.8 9" />
							</svg>
							<span class="brand_name">Elite</span>
							<span class="brand_place">Cap Cana</span>
						</a>

						<h2 class="section_title" id="residencias_title">Apartamentos con vistas al mar</h2>
						<span class="entrance_rule gold_rule" aria-hidden="true"></span>
						<p class="section_text">
							Residencias exclusivas de 1, 2 y 3 habitaciones, con diseño sofisticado,
							espacios amplios y terrazas que se abren al Caribe.
						</p>
					</div>

					<div class="residence_carousel" data-residence-carousel>
						<div class="residence_cards_view">
							<div class="residence_cards_track" data-residence-track>
								<article class="residence_card">
									<div class="residence_card_media">
										<img src="/assets/section_residencias/residence_card_view.webp" alt="" loading="lazy" decoding="async" />
									</div>
									<img class="residence_floorplan" src="/assets/section_residencias/floorplan_tipo_a_1hab.webp" alt="Plano tipo A de 1 habitación" loading="lazy" decoding="async" />
									<div class="residence_card_body">
										<h3>Tipo A</h3>
										<p class="residence_card_fact">
											<svg class="stat_icon line_icon" viewBox="0 0 44 44" aria-hidden="true">
												<path d="M9 31V17" />
												<path d="M9 23h26c3 0 5 2 5 5v3" />
												<path d="M9 31h31" />
												<path d="M14 23v-6h9c3 0 5 2 5 5v1" />
												<path d="M13 35v-4M38 35v-4" />
											</svg>
											<span>1 Habitación</span>
										</p>
										<p class="residence_card_fact">
											<svg class="stat_icon area_icon" viewBox="0 0 24 25" aria-hidden="true">
												<path d="M17 23.6343V19.6343H7C6.45 19.6343 5.97917 19.4384 5.5875 19.0468C5.19583 18.6551 5 18.1843 5 17.6343V7.63428H1V5.63428H5V1.63428H7V17.6343H23V19.6343H19V23.6343H17ZM17 15.6343V7.63428H9V5.63428H17C17.55 5.63428 18.0208 5.83011 18.4125 6.22178C18.8042 6.61344 19 7.08428 19 7.63428V15.6343H17Z" />
											</svg>
											<span>Interior: 65.37 m²</span>
										</p>
										<a href="/assets/section_residencias/map_floorplan_tipo_a_1hab.webp" data-residence-modal-src="/assets/section_residencias/map_floorplan_tipo_a_1hab.webp">Ver más</a>
									</div>
