---
import "@fontsource/cormorant-garamond/400.css";
import "@fontsource/cormorant-garamond/500.css";
import "@fontsource/manrope/400.css";
import "@fontsource/manrope/500.css";
import "@fontsource/manrope/600.css";
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Elite Cap Cana, residencias exclusivas frente al Caribe en una de las comunidades mas prestigiosas de Republica Dominicana."
		/>
		<title>Elite Cap Cana | Residencias frente al Caribe</title>
	</head>
	<body>
		<main class="site_shell">
			<section class="hero_section" aria-label="Elite Cap Cana">
				<img
					class="hero_image"
					src="/assets/hero/hero_residences_caribbean_luxury.png"
					alt="Residencias de lujo frente al Caribe con piscina infinita y palmeras en Cap Cana"
					loading="eager"
					decoding="async"
					fetchpriority="high"
				/>
				<div class="hero_overlay hero_overlay_left"></div>
				<div class="hero_overlay hero_overlay_top"></div>
				<div class="hero_overlay hero_overlay_bottom"></div>

				<header class="site_header">
					<nav class="site_nav" aria-label="Navegacion principal">
						<div class="nav_group nav_group_left">
							<a href="#residencias">Residencias</a>
							<a href="#terrenos">Terrenos</a>
							<a href="#ubicacion">Ubicación</a>
						</div>

						<a class="brand_mark" href="/" aria-label="Elite Cap Cana inicio">
							<svg class="brand_palm_icon" viewBox="0 0 52 52" aria-hidden="true">
								<path d="M26 47V23" />
								<path d="M26 23C21.7 27.4 19.6 32 19.4 37.5" />
								<path d="M26 23C30.3 27.4 32.4 32 32.6 37.5" />
								<path d="M26 21C18.4 20.9 12.6 23.3 8.6 28.2" />
								<path d="M26 21C33.6 20.9 39.4 23.3 43.4 28.2" />
								<path d="M25.8 20.2C20.1 14.8 14.2 12.9 8.2 14.6" />
								<path d="M26.2 20.2C31.9 14.8 37.8 12.9 43.8 14.6" />
								<path d="M26 19.2C24.1 12.9 24.7 7.9 27.8 4.1" />
								<path d="M26 19.2C28.7 13.7 32.4 10.3 37.2 9" />
								<path d="M26 19.2C23.3 13.7 19.6 10.3 14.8 9" />
							</svg>
							<span class="brand_name">Elite</span>
							<span class="brand_place">Cap Cana</span>
						</a>

						<div class="nav_group nav_group_right">
							<a href="#amenidades">Amenidades</a>
							<a href="#galeria">Galería</a>
							<a class="nav_contact" href="#contacto">Contacto</a>
						</div>
					</nav>
				</header>

				<div class="hero_content_wrap">
					<div class="hero_content">
						<h1>Invierte en Cap Cana. Vive frente al Caribe.</h1>
						<p class="hero_kicker">Un destino extraordinario. Una inversión excepcional.</p>

						<div class="hero_actions">
							<a class="primary_cta" href="#contacto">
								<span>Solicita información</span>
								<span class="cta_arrow" aria-hidden="true"></span>
							</a>
							<div class="hero_hint" aria-hidden="true">
								<svg class="hint_arrow_icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 100" aria-hidden="true">
									<path d="M 175,25 C 140,65 75,75 35,45 M 35,45 L 65,37 M 35,45 L 53,70" />
								</svg>
								<span>Te conecta<br />con nuestro formulario<br />de contacto.</span>
							</div>
						</div>
					</div>
				</div>

				<a class="scroll_cue" href="#entrada" aria-label="Ir a la siguiente seccion">
					<span class="scroll_mouse"></span>
					<span class="scroll_line"></span>
				</a>
			</section>

			<section class="entrance_section" id="entrada" aria-labelledby="entrada_title">
				<div class="entrance_inner">
					<div class="entrance_copy">
						<svg class="entrance_palm_icon" viewBox="0 0 52 52" aria-hidden="true">
							<path d="M26 47V23" />
							<path d="M26 23C21.7 27.4 19.6 32 19.4 37.5" />
							<path d="M26 23C30.3 27.4 32.4 32 32.6 37.5" />
							<path d="M26 21C18.4 20.9 12.6 23.3 8.6 28.2" />
							<path d="M26 21C33.6 20.9 39.4 23.3 43.4 28.2" />
							<path d="M25.8 20.2C20.1 14.8 14.2 12.9 8.2 14.6" />
							<path d="M26.2 20.2C31.9 14.8 37.8 12.9 43.8 14.6" />
							<path d="M26 19.2C24.1 12.9 24.7 7.9 27.8 4.1" />
							<path d="M26 19.2C28.7 13.7 32.4 10.3 37.2 9" />
							<path d="M26 19.2C23.3 13.7 19.6 10.3 14.8 9" />
						</svg>

						<h2 id="entrada_title">Entrada elegante<br />a una vida de lujo</h2>
						<span class="entrance_rule" aria-hidden="true"></span>
						<p>
							Elite Cap Cana es un proyecto residencial exclusivo dentro de la comunidad mas
							prestigiosa del Caribe. Disenado para quienes buscan elevar su estilo de vida
							y hacer una inversion con vision de futuro.
						</p>

						<div class="entrance_stats" aria-label="Datos principales del proyecto">
							<div class="entrance_stat">
								<svg class="stat_icon" viewBox="0 0 44 44" aria-hidden="true">
									<path d="M11 37V13l11-5 11 5v24" />
									<path d="M16 37V19h12v18" />
									<path d="M18 24h2M24 24h2M18 29h2M24 29h2" />
									<path d="M8 37h28" />
								</svg>
								<strong>113</strong>
								<span>Residencias<br />exclusivas</span>
							</div>
							<div class="entrance_stat">
								<svg class="stat_icon" viewBox="0 0 44 44" aria-hidden="true">
									<path d="M9 31V17" />
									<path d="M9 23h26c3 0 5 2 5 5v3" />
									<path d="M9 31h31" />
									<path d="M14 23v-6h9c3 0 5 2 5 5v1" />
									<path d="M13 35v-4M38 35v-4" />
								</svg>
								<strong>1, 2 y 4</strong>
								<span>Habitaciones</span>
							</div>
							<div class="entrance_stat">
								<svg class="stat_icon" viewBox="0 0 44 44" aria-hidden="true">
									<path d="M6 23c4-5 8-5 12 0s8 5 12 0 6-5 8-3" />
									<path d="M6 31c4-5 8-5 12 0s8 5 12 0 6-5 8-3" />
								</svg>
								<span>Vistas al mar</span>
								<span>y Farallón</span>
							</div>
						</div>
					</div>

					<div class="entrance_visual" aria-hidden="true">
						<img
							src="/assets/section_entrada/entrada_residences_aerial.png"
							alt=""
							loading="lazy"
							decoding="async"
						/>
					</div>
				</div>
			</section>
		</main>
	</body>
</html>

<style>
	:root {
		--color_deep_teal: #042f35;
		--color_teal_black: #001d22;
		--color_gold: #d2a866;
		--color_gold_soft: #e1bb79;
		--color_ivory: #f8f3ea;
		--font_display: "Cormorant Garamond", Georgia, serif;
		--font_body: "Manrope", Arial, sans-serif;
		--site_max_width: 1280px;
	}

	* {
		box-sizing: border-box;
	}

	html {
		background: var(--color_teal_black);
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		color: var(--color_ivory);
		font-family: var(--font_body);
		background: var(--color_teal_black);
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.site_shell {
		min-height: 100dvh;
		overflow: hidden;
	}

	.hero_section {
		position: relative;
		min-height: 780px;
		height: 100dvh;
		max-height: 900px;
		isolation: isolate;
		overflow: hidden;
		background: var(--color_deep_teal);
	}

	.hero_image {
		position: absolute;
		inset: 0;
		z-index: -4;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: 58% 50%;
		filter: saturate(0.92) contrast(1.04) brightness(0.84);
		transform: scale(1.01);
	}

	.hero_overlay {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}



	.hero_overlay_top {
		z-index: -2;
		background: linear-gradient(180deg, rgba(0, 18, 22, 0.82) 0%, rgba(0, 18, 22, 0.32) 18%, transparent 46%);
	}

	.hero_overlay_bottom {
		z-index: -1;
		background:
			linear-gradient(0deg, rgba(0, 18, 20, 0.78) 0%, rgba(0, 18, 20, 0.26) 20%, transparent 44%),
			radial-gradient(circle at 64% 76%, rgba(210, 168, 102, 0.12), transparent 22%);
	}

	.site_header {
		position: absolute;
		top: 0;
		left: 0;
		z-index: 5;
		width: 100%;
		padding: 31px 32px 0;
	}

	.site_nav {
		position: relative;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: start;
		width: min(100%, var(--site_max_width));
		margin: 0 auto;
		min-height: 92px;
		align-items: center;
		
	}

	.nav_group {
		display: flex;
		align-items: center;
		gap: clamp(22px, 3vw, 44px);
		padding-top: 25px;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.105em;
		line-height: 1;
		text-transform: uppercase;
		text-shadow: 0 1px 18px rgba(0, 0, 0, 0.35);
		white-space: nowrap;
		margin-top: -16px;
	}

	.nav_group_right {
		justify-content: flex-end;
		gap: clamp(24px, 3vw, 38px);
	}

	.nav_group a {
		transition: color 180ms ease, opacity 180ms ease;
	}

	.nav_group a:hover {
		color: var(--color_gold_soft);
	}

	.nav_contact {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 112px;
		height: 32px;
		padding: 0 19px;
		border: 1px solid rgba(210, 168, 102, 0.9);
		color: #fff9ef;
	}

	.brand_mark {
		display: grid;
		justify-items: center;
		margin-top: 2px;
		color: #fffdf6;
		text-align: center;
		text-shadow: 0 2px 22px rgba(0, 0, 0, 0.34);
	}

	.brand_palm_icon {
		width: 38px;
		height: 38px;
		margin-bottom: 3px;
		overflow: visible;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.35;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.brand_name {
		font-family: var(--font_display);
		font-size: 38px;
		font-weight: 500;
		line-height: 0.82;
		letter-spacing: 0.22em;
		text-transform: uppercase;
	}

	.brand_place {
		margin-top: 12px;
		font-size: 15px;
		font-weight: 400;
		letter-spacing: 0.42em;
		line-height: 1;
		text-transform: uppercase;
			font-family: var(--font_display);
	}

	.hero_content_wrap {
		position: relative;
		z-index: 3;
		display: flex;
		align-items: center;
		width: min(100%, var(--site_max_width));
		height: 100%;
		margin: 0 auto;
		padding: 118px 32px 88px;
	}

	.hero_content {
		width: min(100%, 545px);
		margin-top: 48px;
	}

	.hero_content h1 {
		max-width: 450px;
		margin: 0;
		font-family: var(--font_display);
		font-size: clamp(4rem,6.1vw,5rem);
		font-weight: 400;
		letter-spacing: 0;
		line-height: 0.96;
		color: #fffaf0;
		text-wrap: balance;
		text-shadow: 0 3px 28px rgba(0, 0, 0, 0.24);
	}

	.hero_kicker {
		max-width: 275px;
		margin: 29px 0 0;
		font-size: 14px;
		font-weight: 600;
		letter-spacing: 0.118em;
		line-height: 1.7;
		text-transform: uppercase;
		color: rgba(255, 249, 239, 0.92);
		text-shadow: 0 2px 18px rgba(0, 0, 0, 0.28);
	}

	.hero_actions {
		display: flex;
		align-items: center;
		gap: 19px;
		margin-top: 32px;
	}

	.primary_cta {
		display: inline-flex;
		align-items: center;
		justify-content: space-between;
		width: min(100%, 300px);
		letter-spacing: 1%;
		min-height: 63px;
		padding: 0 29px;
		border-radius: 0.25rem;
		border: 2px solid var(--color_gold);
		background: rgba(3, 58, 61, 0.86);
		box-shadow: 0 20px 54px rgba(0, 0, 0, 0.19);
		color: #fffaf0;
		font-size: 16px;
		font-weight: 500;
		line-height: 1;
		transition: background 180ms ease, border-color 180ms ease, transform 180ms ease;
	}

	.primary_cta:hover {
		background: rgba(8, 70, 72, 0.95);
		border-color: #e3bf7f;
	}

	.primary_cta:active {
		transform: translateY(1px);
	}

	.cta_arrow {
		position: relative;
		width: 31px;
		height: 1px;
		background: var(--color_gold);
	}

	.cta_arrow::after {
		position: absolute;
		top: -4px;
		right: 0;
		width: 9px;
		height: 9px;
		content: "";
		border-top: 1px solid var(--color_gold);
		border-right: 1px solid var(--color_gold);
		transform: rotate(45deg);
	}

	.hero_hint {
		display: flex;
		align-items: center;
		gap: 11px;
		color: rgba(255, 249, 239, 0.86);
		font-family: var(--font_display);
		font-size: 18px;
		font-style: italic;
		line-height: 1.05;
		text-shadow: 0 2px 18px rgba(0, 0, 0, 0.38);
	}

	.hint_arrow_icon {
		width: 62px;
		height: 32px;
		flex: 0 0 auto;
		overflow: visible;
		fill: none;
		stroke: rgba(255, 249, 239, 0.86);
		stroke-width: 6;
		stroke-linecap: round;
		stroke-linejoin: round;
		transform: translateY(-4px);
	}

	.scroll_cue {
		position: absolute;
		left: 50%;
		bottom: 24px;
		z-index: 5;
		display: grid;
		justify-items: center;
		gap: 5px;
		width: 28px;
		color: #fffaf0;
		transform: translateX(-50%);
		opacity: 0.92;
	}

	.scroll_mouse {
		position: relative;
		width: 22px;
		height: 36px;
		border: 1px solid rgba(255, 250, 240, 0.9);
		border-radius: 999px;
	}

	.scroll_mouse::after {
		position: absolute;
		top: 7px;
		left: 50%;
		width: 3px;
		height: 8px;
		content: "";
		border-radius: 999px;
		background: rgba(255, 250, 240, 0.9);
		transform: translateX(-50%);
	}

	.scroll_line {
		position: relative;
		width: 1px;
		height: 18px;
		background: rgba(255, 250, 240, 0.72);
		display: none;
	}

	.scroll_line::after {
		position: absolute;
		right: -4px;
		bottom: 0;
		width: 8px;
		height: 8px;
		content: "";
		border-right: 1px solid rgba(255, 250, 240, 0.72);
		border-bottom: 1px solid rgba(255, 250, 240, 0.72);
		transform: rotate(45deg);
	}

	.entrance_section {
		position: relative;
		overflow: hidden;
		background:
			radial-gradient(circle at 9% 14%, rgba(210, 168, 102, 0.1), transparent 18%),
			linear-gradient(90deg, #f9f4eb 0%, #fbf7ef 47%, #f6efe3 100%);
		color: var(--color_deep_teal);
	}

	.entrance_inner {
		position: relative;
		display: grid;
		grid-template-columns: minmax(340px, 0.43fr) minmax(0, 0.57fr);
		align-items: center;
		width: min(100%, var(--site_max_width));
		min-height: 594px;
		margin: 0 auto;
		padding: 70px 32px 74px;
	}

	.entrance_copy {
		position: relative;
		z-index: 2;
		max-width: 440px;
		font-weight: 500;
	}

	.entrance_palm_icon {
		width: 40px;
		height: 40px;
		overflow: visible;
		fill: none;
		stroke: var(--color_gold);
		stroke-width: 1.45;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.entrance_copy h2 {
		max-width: 650px;
		margin: 0;
		font-family: var(--font_display);
		font-size: clamp(3.55rem, 5.2vw, 4rem);
		font-weight: 500;
		letter-spacing: -0.02em;
		line-height: 1.1;
		color: #07343a;
		text-wrap: balance;
	}

	.entrance_rule {
		display: block;
		width: 55px;
		height: 2px;
		margin: 24px 0 24px;
		background: var(--color_gold);
	}

	.entrance_copy p {
		max-width: 400px;
		margin: 0;
		color: rgba(7, 52, 58, 0.8);
		font-size: 15px;
		font-weight: 500;
		line-height: 1.72;
	}

	.entrance_stats {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		width: min(100%, 422px);
		margin-top: 54px;
	}

	.entrance_stat {
		min-height: 124px;
		padding: 0 23px;
		border-left: 1px solid rgba(7, 52, 58, 0.22);
		color: #07343a;
		text-align: center;
	}

	.entrance_stat:first-child {
		padding-left: 0;
		border-left: 0;
	}

	.stat_icon {
		display: block;
		width: 45px;
		height: 45px;
		margin: 0 auto 13px;
		fill: none;
		stroke: #796640;
		stroke-width: 1.45;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.entrance_stat strong {
		display: block;
		font-size: 24px;
		font-weight: 500;
		line-height: 1.15;
		color: #07343a;
	}

	.entrance_stat span {
		display: block;
		margin-top: 8px;
		color: rgba(7, 52, 58, 0.82);
		font-size: 14px;
		font-weight: 500;
		line-height: 1.25;
	}

	.entrance_visual {
		position: absolute;
		top: -1px;
		right: calc((100vw - min(100vw, var(--site_max_width))) / -2);
		bottom: 0;
		width: calc(57vw + max(0px, (100vw - var(--site_max_width)) / 2));
		border-left: 1px solid rgba(210, 168, 102, 0.52);
		overflow: hidden;
		max-width: 50vw;
	}

	.entrance_visual::before {
		position: absolute;
		inset: 0;
		z-index: 1;
		content: "";
		background: linear-gradient(90deg, rgba(251, 247, 239, 0.16), transparent 22%);
		pointer-events: none;
	}

	.entrance_visual img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: 52% 50%;
		filter: saturate(0.94) contrast(1.02) brightness(1.02);
	}

	@media (max-width: 1180px) {
		.nav_group {
			gap: 20px;
			font-size: 10px;
			letter-spacing: 0.08em;
		}

		.brand_name {
			font-size: 34px;
		}

		.brand_place {
			font-size: 13px;
		}

		.hero_content h1 {
			max-width: 470px;
			font-size: clamp(3.5rem, 6.4vw, 4.2rem);
		}

		.entrance_inner {
			grid-template-columns: minmax(320px, 0.45fr) minmax(0, 0.55fr);
		}

		.entrance_visual {
			right: 0;
			width: 58vw;
		}
	}

	@media (max-width: 900px) {
		.hero_section {
			min-height: 720px;
			max-height: none;
		}

		.hero_image {
			object-position: 68% 50%;
		}

	

		.site_header {
			padding: 25px 22px 0;
		}

		.site_nav {
			grid-template-columns: 1fr auto;
			align-items: center;
			min-height: 78px;
		}

		.nav_group_left {
			display: none;
		}

		.nav_group_right {
			grid-column: 2;
			gap: 18px;
			padding-top: 0;
		}

		.nav_group_right a:not(.nav_contact) {
			display: none;
		}

		.brand_mark {
			grid-column: 1;
			grid-row: 1;
			justify-items: start;
			margin-top: 0;
		}

		.brand_palm_icon {
			width: 28px;
			height: 28px;
			margin-left: 48px;
		}

		.brand_name {
			font-size: 31px;
		}

		.brand_place {
			margin-top: 9px;
			font-size: 11px;
			letter-spacing: 0.36em;
		}

		.hero_content_wrap {
			align-items: flex-end;
			padding: 130px 24px 94px;
